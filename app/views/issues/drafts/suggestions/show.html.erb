<section class="report">
  <%= link_to issues_draft_geo_path(@draft), class: "button-back" do %>
    <span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 20">
        <path d="M1,19l9-9L1,1" fill="none" stroke-width="2"/>
      </svg>
    </span>
    <span>Späť</span>
  <% end %>

  <% if @draft.suggestions %>
    <%= render partial: 'suggestions', object: @draft.suggestions %>
  <% else %>
    <%= turbo_frame_tag @draft, src: generate_issues_draft_suggestions_path(@draft), target: :_top do %>
      <section class="loader-con">
        <h1>Analyzujú sa fotky</h1>
        <%= image_tag "loading.gif", style: "width: 10em; margin: 0 auto; display: block;" %>
      </section>
    <% end %>
  <% end %>
</section>
