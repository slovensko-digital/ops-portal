<section class="forms-container report">
  <h1><%= rodauth.reset_password_request_page_title %></h1>

  <%= form_with url: rodauth.reset_password_request_path, method: :post, data: { turbo: false }, class: "w-full max-w-sm", html: { novalidate: true } do |form| %>
    <div class="form-other-con">
      <div class="form-description">
        <%== rodauth.reset_password_explanatory_text %>
      </div>
      <div class="form-items-con">
        <div class="form-item-wrapper">

        <% if params[rodauth.login_param] && !rodauth.field_error(rodauth.login_param) %>
        <%= form.hidden_field rodauth.login_param, value: params[rodauth.login_param] %>
      <% else %>
        <%= form.label "login", rodauth.login_label, class: "block text-sm font-semibold" %>
        <%= form.email_field rodauth.login_param, value: params[rodauth.login_param], id: "login", autocomplete: "email", required: true, aria: ({ invalid: true, describedby: "login_error_message" } if rodauth.field_error(rodauth.login_param)) %>
        <%= content_tag(:span, rodauth.field_error(rodauth.login_param), class: "error-message", id: "login_error_message") if rodauth.field_error(rodauth.login_param) %>
      <% end %>
        </div>
      </div>
      <%= form.submit rodauth.reset_password_request_button, class: "button" %>
    </div>
  <% end %>
</section>
