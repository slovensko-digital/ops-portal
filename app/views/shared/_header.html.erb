        </div>
      </div>
    </div>



    <div class="nav-wrap-main">
      <div class="nav-con-main">
        <%= link_to "Nahlásiť&nbsp;podnet".html_safe, new_issues_draft_path, class: "button-main" %>
        <%= link_to "Položit&nbsp;otázku".html_safe, new_question_path %>
        <%= link_to "Dať&nbsp;pochvalu".html_safe, new_praise_path %>
        <div class="search-con">
          <%= form_tag issues_path, method: :get do %>
            <% if @search_results %>
              <% @search_results.search_params.except(:q).each do |k, v| %>
                <%= hidden_field_tag k, v %>
              <% end %>
            <% end %>
            <button>
              <svg viewBox="0 0 19 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="7.77818" cy="8.27818" r="6.77818"/>
                <path d="M13 13.5L18 18.5"/>
              </svg>
            </button>
            <%= search_field_tag :q, params[:q], id: nil, placeholder: "Hľadaj obec alebo kľúčové slovo" %>
          <% end %>
        </div>
      </div>
    </div>

  </nav>

</header>