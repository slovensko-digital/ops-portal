<% content_for(:title, rodauth.verify_login_change_page_title) %>

<section class="forms-container report">
  <h1><%= rodauth.verify_login_change_page_title %></h1>

  <div class="form-other-con">
    <div class="form-description">Potvrďte zmenu emailu z <strong><%= rodauth.verify_login_change_old_login %></strong> na <strong><%= rodauth.verify_login_change_new_login %></strong>.</div>

    <%= form_with url: rodauth.verify_login_change_path, method: :post, data: { turbo: false }, html: { novalidate: true } do |form| %>
      <div class="form-items-con">
        <%= form.submit rodauth.verify_login_change_button, class: "button" %>
      </div>
    <% end %>
  </div>
</section>
