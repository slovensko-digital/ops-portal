<div class="form-item-wrapper">
  <label for="<%= autocomplete.control.label %>"><%= autocomplete.control.label %></label>

  <div class="autocomplete-wrapper"
       data-controller="autocomplete toggle"
       data-autocomplete-none-class="none"
       data-action="
        focusin->toggle#show
        focusout->toggle#hide
        input->autocomplete#filter
        keydown.enter->autocomplete#enter">
    <input
      data-autocomplete-target="input"
      placeholder="<%= autocomplete.items.select(&:selected?).map(&:label).join(', ') %>"
      id="<%= autocomplete.control.label %>"
      autocomplete="off" />

    <ul class="dropdown-list none"
        data-toggle-target="toggleable"
        data-toggle-class="none"
        data-autocomplete-target="list" >
      <% autocomplete.items.each do |item| %>
        <li
          data-autocomplete-target="item"
          class="<%= class_names("check-box": autocomplete.multiple, active: item.selected?) %>" >
          <%= link_to item.selected? ? item.remove_params : item.add_params, class: '' do %>
            <% if autocomplete.multiple %>
              <div class="form-check-box">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 20">
                  <polygon points="5.51 15.78 0 10.26 1.06 9.2 5.51 13.66 14.94 4.22 16 5.28 5.51 15.78"/>
                </svg>
              </div>
            <% end %>
            <span><%= item.label %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>