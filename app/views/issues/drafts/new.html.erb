<section class="report">
  <h1><%= t "issues/drafts.new_#{@draft.issue_type}" %></h1>

  <div class="report-suggestion-description">Nahrajte fotografiu k podnetu. Ak používate mobil, odporúčame zapnúť
    lokalizáciu GPS.
  </div>

  <% @draft.errors.full_messages_for(:photos).each do |msg| %>
    <div class="error-message error-summary"><%= msg %></div>
  <% end %>
  <div class="report-suggestion-add-pictures-con">
    <%= form_with(model: @draft, data: { controller: 'auto-submit' }) do |form| %>
      <%= form.hidden_field :issue_type %>
      <div class="report-suggestion-add-pictures-wrapper">
        <%= form.label :photos, class: "button-add-picture" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28">
            <line y1="14" x2="28" y2="14" fill="none" stroke-miterlimit="10"/>
            <line x1="14" x2="14" y2="28" fill="none" stroke-miterlimit="10"/>
          </svg>
        <% end %>
        <div class="info-title">Nahrať fotku</div>
        <%= form.file_field :photos, multiple: true, accept: "capture=camera;image/*", class: 'sr-only', data: { action: 'auto-submit#submit' } %>
        <%= hidden_field_tag :next, params[:next] %>
      </div>
      <%= form.submit data: { "turbo_submits_with": "Nahrávam..." }, class: "sr-only" %>
    <% end %>

    <% if @draft.photos.attached? %>
      <div class="report-suggestion-pictures-block">
        <% @draft.photos.each do |photo| %>
          <figure>
            <%= button_to issues_draft_destroy_photo_path(@draft, photo_id: photo.id, next: params[:next]), class: 'close-button', method: :delete, data: { 'turbo-confirm': 'Určite chcete túto fotku odstrániť?' } do %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 38 38">
                <polygon points="27.71 11.71 26.29 10.29 19 17.59 11.71 10.29 10.29 11.71 17.59 19 10.29 26.29 11.71 27.71 19 20.41 26.29 27.71 27.71 26.29 20.41 19 27.71 11.71"/>
                <path d="M19,38C8.52,38,0,29.48,0,19S8.52,0,19,0s19,8.52,19,19-8.52,19-19,19ZM19,2C9.63,2,2,9.63,2,19s7.63,17,17,17,17-7.63,17-17S28.37,2,19,2Z"/>
              </svg>
            <% end %>
            <picture>
              <% image = photo.variable? ? photo.variant(:square) : 'otazka-znacka.png' %>
              <%= image_tag image, alt: "Uploaded photo" %>
            </picture>
          </figure>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="notice">Nahrajte fotografie, ktoré podnet najlepšie dokumentujú. Maximálna veľkosť: 7MB.
  </div>
  <% if @draft.valid?(:photos_step) %>
    <% if params[:next] == 'summary' %>
      <%= link_to 'Upraviť', issues_draft_summary_path(@draft), class: 'button' %>
    <% else %>
      <%= link_to 'Pokračovať', issues_draft_geo_path(@draft), class: 'button' %>
    <% end %>

  <% end %>
</section>
