<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">New issue</h1>

  <%= form_with(model: @draft, class: "contents") do |form| %>
    <% if @draft.errors.any? %>
      <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
        <h2><%= pluralize(@draft.errors.count, "error") %> prohibited this issue from being saved:</h2>

        <ul>
          <% @draft.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="my-5">
      <%= form.label :photos %>
      <%= form.file_field :photos, multiple: true, accept: "image/*;capture=camera", class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-5 mt-2 w-full" %>
    </div>

    <div class="inline">
      <%= form.submit data: { "turbo_submits_with": "Submitting..." }, class: "rounded-lg py-3 px-5 bg-blue-600 text-white inline-block font-medium cursor-pointer" %>
    </div>
  <% end %>
</div>
