<section class="podnet">
  <div class="podnet-con">
    <!-- Podnet Description & Pictures -->
    <div class="podnet-esential">
      <h1><%= @issue.title %></h1>
      <div class="podnet-description">
        <%= @issue.description %>
      </div>
      <div class="podnet-pictures-con">
        <figure class="big-picture">
          <div class="lens-image">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 38 38">
              <path d="M38,36.59l-10.02-10.02c2.49-2.82,4.02-6.52,4.02-10.57C32,7.18,24.82,0,16,0S0,7.18,0,16s7.18,16,16,16c4.05,0,7.75-1.53,10.57-4.02l10.02,10.02,1.41-1.41ZM16,30c-7.72,0-14-6.28-14-14S8.28,2,16,2s14,6.28,14,14-6.28,14-14,14Z"/>
              <polygon points="23 15 17 15 17 9 15 9 15 15 9 15 9 17 15 17 15 23 17 23 17 17 23 17 23 15"/>
            </svg>
          </div>
          <picture>
            <%= image_tag @issue.photos.first.variant(:small) if @issue.photos.attached? %>
          </picture>
        </figure>
        <% if @issue.photos.count > 1 %>
          <%= @issue.photos[1..].each do |photo| %>
            <figure class="small-picture">
              <div class="lens-image">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 38 38">
                  <path d="M38,36.59l-10.02-10.02c2.49-2.82,4.02-6.52,4.02-10.57C32,7.18,24.82,0,16,0S0,7.18,0,16s7.18,16,16,16c4.05,0,7.75-1.53,10.57-4.02l10.02,10.02,1.41-1.41ZM16,30c-7.72,0-14-6.28-14-14S8.28,2,16,2s14,6.28,14,14-6.28,14-14,14Z"/>
                  <polygon points="23 15 17 15 17 9 15 9 15 15 9 15 9 17 15 17 15 23 17 23 17 17 23 17 23 15"/>
                </svg>
              </div>
              <picture>
                <%= image_tag photo.variant(:small) %>
              </picture>
            </figure>
          <% end %>
        <% end %>
      </div>

      <div class="share-buttons">
        <a class="button button-transparent button-share">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
            <polygon points="1 .78 1 5.7 1 12.59 1 18.59 7 14.99 13 18.59 13 12.59 13 5.7 13 .78 1 .78" stroke="#1c3054" stroke-miterlimit="10" stroke-width="1.5"/>
          </svg>
          <span>Sledovať podnet</span>
        </a>

        <a class="button button-transparent button-like button-active">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
            <path d="M17.46,3.35c-2.06-2.05-5.4-2.05-7.46,0-2.06-2.05-5.4-2.05-7.46,0C.49,5.4.49,8.72,2.54,10.77l7.46,7.41,7.46-7.41c2.06-2.05,2.06-5.37,0-7.41Z" stroke="#1c3054" stroke-miterlimit="10" stroke-width="1.5"/>
          </svg>
          <span>35</span>
        </a>

        <a class="button button-transparent button-share-mobile">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
