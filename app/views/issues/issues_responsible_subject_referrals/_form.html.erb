<%
  current_type = params.dig(:issues_responsible_subject_referral, :referral_type) || "change_subject"
%>

<%= form_with scope: :issues_responsible_subject_referral, url: issue_issues_responsible_subject_referrals_path(issue), method: :post, model: [ issue, comment ] do |f| %>
  <% if comment.errors[:base].any? %>
    <% comment.errors[:base].each do |error| %>
      <div class="error-message"><%= error %></div>
    <% end %>
  <% end %>

  <div class="form-other-con" data-controller="toggle">
    <div class="form-items-con" style="margin-bottom: 1.5rem;">
      <div class="form-radio-button-wrapper" style="flex-direction: column; align-items: flex-start; gap: 10px;">

        <div class="form-radio-button-con">
          <%= f.radio_button :referral_type, "change_subject",
                             id: "referral_type_change",
                             data: { action: "change->toggle#show" } %>

          <%= f.label :referral_type_change, "Preposlať inému zodpovednému subjektu", for: "referral_type_change" %>
        </div>

        <div class="form-notice" style="margin-top: -5px; margin-bottom: 10px; margin-left: 28px; font-size: 0.85rem; color: #666;">
          Uveďte do komentára, akej samospráve alebo subjektu je potrebné podnet preposlať.
        </div>

        <div class="form-radio-button-con">
          <%= f.radio_button :referral_type, "refer",
                             id: "referral_type_refer",
                             data: { action: "change->toggle#hide" } %>

          <%= f.label :referral_type_refer, "Odstúpiť podnet", for: "referral_type_refer" %>
        </div>

        <div class="form-notice" style="margin-top: -5px; margin-bottom: 10px; margin-left: 28px; font-size: 0.85rem; color: #666;">
          Podnet budete riešiť s iným zodpovedným subjektom a budete informovať cez portál o ďalšom postupe.
        </div>

      </div>
    </div>

    <div data-toggle-target="toggleable" data-toggle-class="none">
      <div class="form-item-wrapper"
           id="new-subject-wrapper"
           data-controller="remote-autocomplete"
           data-remote-autocomplete-url-value="/api/v1/responsible_subjects/search"
           data-remote-autocomplete-none-class="none"
           data-action="click@window->remote-autocomplete#hide">

        <label>Nový zodpovedný subjekt</label>
        <input type="text"
               placeholder="Vyhľadajte subjekt..."
               data-remote-autocomplete-target="input"
               data-action="input->remote-autocomplete#search"
               autocomplete="off"
               class="form-input <%= 'error' if comment.errors[:new_responsible_subject_id].any? %>">

        <%= f.hidden_field :new_responsible_subject_id, data: { remote_autocomplete_target: "hidden" } %>

        <ul class="dropdown-list none"
            data-remote-autocomplete-target="results">
        </ul>

        <template data-remote-autocomplete-target="template">
          <li class="autocomplete-item">
            <a href="#"
               data-action="click->remote-autocomplete#select"
               data-remote-autocomplete-id-param=""
               data-remote-autocomplete-name-param="">
            </a>
          </li>
        </template>

        <% comment.errors[:new_responsible_subject_id].each do |error| %>
          <div class="error-message"><%= error %></div>
        <% end %>
      </div>
    </div>

    <%= f.fields_for :comment do |cf| %>
      <div class="form-item-wrapper">
        <label>Komentár</label>

        <%= cf.text_area :text,
                         placeholder: "Napíšte dôvod odstúpenia...",
                         data: { autofocus_target: "input" },
                         class: "#{comment.errors[:text].any? ? 'error' : ''}" %>

        <% comment.errors.full_messages_for(:text).each do |error| %>
          <div class="error-message"><%= error %></div>
        <% end %>
      </div>
    <% end %>

    <div class="buttons-wrapper">
      <%= f.submit "Potvrdiť", class: "button submit" %>
    </div>
  </div>
<% end %>
