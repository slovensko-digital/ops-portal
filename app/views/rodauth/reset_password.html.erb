<% content_for(:title, rodauth.reset_password_page_title) %>

<section class="forms-container report">
  <h1><%= rodauth.reset_password_page_title %></h1>

  <div class="form-other-con">
    <div class="form-description">Polia označené * sú povinné.</div>

    <%= form_with url: rodauth.reset_password_path, method: :post, data: { turbo: false }, html: { novalidate: true } do |form| %>
      <div class="form-items-con">
        <div class="form-item-wrapper">
          <%= form.label "password", "#{rodauth.password_label}*" %>
          <%= form.password_field rodauth.password_param, value: "", id: "password", autocomplete: rodauth.password_field_autocomplete_value, required: true, aria: ({ invalid: true, describedby: "password_error_message" } if rodauth.field_error(rodauth.password_param)) %>
          <%= content_tag(:span, rodauth.field_error(rodauth.password_param), class: "error-message", id: "password_error_message") if rodauth.field_error(rodauth.password_param) %>
        </div>

        <% if rodauth.require_password_confirmation? %>
          <div class="form-item-wrapper">
            <%= form.label "password-confirm", "#{rodauth.password_confirm_label}*" %>
            <%= form.password_field rodauth.password_confirm_param, value: "", id: "password-confirm", autocomplete: "new-password", required: true, aria: ({ invalid: true, describedby: "password-confirm_error_message" } if rodauth.field_error(rodauth.password_confirm_param)) %>
            <%= content_tag(:span, rodauth.field_error(rodauth.password_confirm_param), class: "error-message", id: "password-confirm_error_message") if rodauth.field_error(rodauth.password_confirm_param) %>
          </div>
        <% end %>

        <%= form.submit rodauth.reset_password_button, class: "button" %>
      </div>
    <% end %>
  </div>
</section>
