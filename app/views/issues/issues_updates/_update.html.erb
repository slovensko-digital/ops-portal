<% comment = update %>
<%= turbo_frame_tag comment do %>
  <div class="<%= class_names("comment confirm-comment") %>" id="komentar_<%= comment.id %>">
    <% if comment.confirmed_by_id? || comment.confirmed? %>
      <div class="confirm-status-con">
        <div class="confirm-status">
          <svg id="Layer_1" xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 17 12">
            <polygon points="7 11.2 .47 4.67 1.53 3.61 7 9.08 15.75 .33 16.81 1.39 7 11.2"></polygon>
          </svg>
          <span>Overené</span>
        </div>
      </div>
    <% end %>
    <div class="subject">
      <figure>
        <picture>
          <%= user_avatar(comment.author) %>
        </picture>
      </figure>
      <div class="name"><%= comment.author_display_name %></div>
    </div>
    <div class="date"><%= l comment.created_at.to_date %></div>
    <% if comment.text.present? %>
      <div class="comment-content">
        <%= simple_format(comment.text) %>
      </div>
    <% end %>
    <% if comment.attachments.any? %>
      <%= render "issues/activity_object_attachments", activity_object: comment %>
    <% end %>

    <div class="like-dislike-confirm-con">
      <%= render partial: "issues/activity_votes/buttons", locals: { activity: comment.activity } %>
      <!--    <a class="button-confirm">-->
      <!--      <svg xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 20 20">-->
      <!--        <path d="M10,20C4.49,20,0,15.51,0,10S4.49,0,10,0s10,4.49,10,10-4.49,10-10,10ZM10,1.46C5.29,1.46,1.46,5.29,1.46,10s3.83,8.54,8.54,8.54,8.54-3.83,8.54-8.54S14.71,1.46,10,1.46Z"/>-->
      <!--        <path d="M10,11.59c-.4,0-.73-.33-.73-.73v-5.85c0-.4.33-.73.73-.73s.73.33.73.73v5.85c0,.4-.33.73-.73.73Z"/>-->
      <!--        <circle cx="10" cy="14.02" r=".98"/>-->
      <!--      </svg>-->
      <!--      <span>Nahlásiť komentár</span>-->
      <!--    </a>-->
      <% if comment.editable_by?(current_user) %>
        <div class="like-dislike-con">
          <%= link_to "Upraviť", edit_issue_issues_update_path(comment.activity.issue, comment), class: "button button-md button-edit" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>