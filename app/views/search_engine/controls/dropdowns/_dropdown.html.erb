<div class="form-item-wrapper" data-controller="toggle">
  <label><%= dropdown.control.label %></label>
  <div class="dropdown-button" data-action="click->toggle#toggle">
    <% selected = dropdown.items.select(&:selected?) %>
    <% if selected.any? %>
      <span title="<%= selected.map(&:label).join(', ') %>"><%= selected.map(&:label).join(', ') %></span>
    <% else %>
      Všetko
    <% end %>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
      <polygon points="7 14.07 0 7.07 1.14 5.93 7 11.79 12.86 5.93 14 7.07 7 14.07"/>
    </svg>
  </div>
  <ul class="dropdown-list none" data-toggle-target="toggleable" data-toggle-class="none">
    <% dropdown.items.each do |item| %>
      <li class="<%= class_names("check-box", active: item.selected?) %>">
        <%= link_to item.selected? ? item.remove_params : item.add_params, class: '' do %>
          <div class="form-check-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 20">
              <polygon points="5.51 15.78 0 10.26 1.06 9.2 5.51 13.66 14.94 4.22 16 5.28 5.51 15.78"/>
            </svg>
          </div>
          <span><%= item.label %></span>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
