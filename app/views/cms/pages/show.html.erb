<div class="max-w-3xl mx-auto p-6">
  <% if @category %>
    <%= link_to "← Back to #{@category.name}", :back, class: "text-blue-600 hover:underline flex items-center mb-4" %>
  <% end %>
  <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @page.title %></h1>
  <p class="text-gray-500 text-sm mb-4">Published on <%= format_date @page.created_at %></p>
  <img src="https://placehold.co/800x400.png" alt="News Image" class="w-full rounded-lg mb-6">
  <div class="flex flex-col text-gray-700 gap-2">
    <%= sanitize @page.text, tags: %w(p strong i em a img h2 h3 h4 h5 div ol ul li), attributes: %w(href alt class title style target) %>
  </div>
</div>
