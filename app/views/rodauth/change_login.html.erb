<% content_for(:title, rodauth.change_login_page_title) %>

<section class="forms-container report">
  <h1><%= rodauth.change_login_page_title %></h1>

  <div class="form-other-con">
    <%= form_with url: rodauth.change_login_path, method: :post, data: { turbo: false }, html: { novalidate: true } do |form| %>
      <div class="form-items-con">
        <div class="form-item-wrapper">
          <%= form.label "login", "#{rodauth.login_label}*" %>
          <%= form.email_field rodauth.login_param, value: params[rodauth.login_param], id: "login", autocomplete: "email", required: true, aria: ({ invalid: true, describedby: "login_error_message" } if rodauth.field_error(rodauth.login_param)) %>
          <%= content_tag(:span, rodauth.field_error(rodauth.login_param), class: "error-message", id: "login_error_message") if rodauth.field_error(rodauth.login_param) %>
        </div>

        <% if rodauth.require_login_confirmation? %>
          <div class="form-item-wrapper">
            <%= form.label "login-confirm", "#{rodauth.login_confirm_label}*" %>
            <%= form.email_field rodauth.login_confirm_param, value: params[rodauth.login_confirm_param], id: "login-confirm", autocomplete: "email", required: true, aria: ({ invalid: true, describedby: "login-confirm_error_message" } if rodauth.field_error(rodauth.login_confirm_param)) %>
            <%= content_tag(:span, rodauth.field_error(rodauth.login_confirm_param), class: "error-message", id: "login-confirm_error_message") if rodauth.field_error(rodauth.login_confirm_param) %>
          </div>
        <% end %>

        <% if rodauth.change_login_requires_password? %>
          <div class="form-item-wrapper">
            <%= form.label "password", "#{rodauth.password_label}*" %>
            <%= form.password_field rodauth.password_param, value: "", id: "password", autocomplete: rodauth.password_field_autocomplete_value, required: true, aria: ({ invalid: true, describedby: "password_error_message" } if rodauth.field_error(rodauth.password_param)) %>
            <%= content_tag(:span, rodauth.field_error(rodauth.password_param), class: "error-message", id: "password_error_message") if rodauth.field_error(rodauth.password_param) %>
          </div>
        <% end %>

        <%= form.submit rodauth.change_login_button, class: "button" %>
      </div>
    <% end %>
  </div>
</section>
