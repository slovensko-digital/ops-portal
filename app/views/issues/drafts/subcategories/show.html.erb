<%= content_for(:title, 'Výber podkategórie problému') %>

<section class="report">
  <%= link_to issues_draft_category_path(@draft), class: "button-back" do %>
    <span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 20">
        <path d="M1,19l9-9L1,1" fill="none" stroke-width="2"/>
      </svg>
    </span>
    <span>Späť</span>
  <% end %>

  <% if @draft.municipality_errors? %>
    <%= render partial: 'issues/drafts/unsupported_municipality' %>
  <% end %>

  <h1>Výber podkategórie problému</h1>

  <div class="report-suggestion-description">Vyberte podkategóriu problému, ktorý nahlasujete.</div>

  <div class="report-summary-block-con">
    <% @subcategories.each do |sub| %>
      <%= button_to issues_draft_subcategory_path(@draft), method: :patch, class: class_names("button-report-summary button-category", active: sub == @draft.subcategory) do %>
        <%= hidden_field_tag :subcategory_id, sub.id %>
        <%= hidden_field_tag :next, params[:next] %>
        <div class="report-summary-wrapper">
          <div class="title"><%= sub.name %></div>
          <div class="description"><%= sub.description %></div>
        </div>
        <div class="icon-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 20">
            <path d="M1,19l9-9L1,1" fill="none" stroke="#1c3054" stroke-width="2"/>
          </svg>
        </div>
      <% end %>
    <% end %>
  </div>

</section>