<section class="podnety">
  <h1>Nahlásené dopyty</h1>

  <div class="podnety-general-con">
    <div class="podnety-filter-con">
      <div class="podnety-filter-wrapper">
        <div class="podnety-filter-secondary-wrapper">

          <div class="filter-title-con">
            <div class="filter-title">Filter</div>
            <a class="button-close-gen close-filter">
              <span></span>
              <span></span>
            </a>
          </div>

          <div class="filter-select-buttons-con">
            <button class="button button-transparent filter-select-button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                <polygon points="14 4.06 12.94 3 7 8.94 1.06 3 0 4.06 5.94 10 0 15.94 1.06 17 7 11.06 12.94 17 14 15.94 8.06 10 14 4.06"/>
              </svg>
              Všetky
            </button>
            <button class="button button-transparent filter-select-button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                <polygon points="14 4.06 12.94 3 7 8.94 1.06 3 0 4.06 5.94 10 0 15.94 1.06 17 7 11.06 12.94 17 14 15.94 8.06 10 14 4.06"/>
              </svg>
              Podnety
            </button>
            <button class="button button-transparent filter-select-button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                <polygon points="14 4.06 12.94 3 7 8.94 1.06 3 0 4.06 5.94 10 0 15.94 1.06 17 7 11.06 12.94 17 14 15.94 8.06 10 14 4.06"/>
              </svg>
              Vyriešené
            </button>
            <button class="button button-transparent filter-select-button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                <polygon points="14 4.06 12.94 3 7 8.94 1.06 3 0 4.06 5.94 10 0 15.94 1.06 17 7 11.06 12.94 17 14 15.94 8.06 10 14 4.06"/>
              </svg>
              Nitra
            </button>
            <button class="button button-transparent filter-select-button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                <polygon points="14 4.06 12.94 3 7 8.94 1.06 3 0 4.06 5.94 10 0 15.94 1.06 17 7 11.06 12.94 17 14 15.94 8.06 10 14 4.06"/>
              </svg>
              Cesty a chodníky
            </button>
          </div>

          <form action="">

            <div class="form-other-con">
              <div class="form-items-con">

                <div class="form-item-wrapper">
                  <label for="title">Typ dopytu</label>
                  <div class="dropdown-button">
                    Všetko
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                      <polygon points="7 14.07 0 7.07 1.14 5.93 7 11.79 12.86 5.93 14 7.07 7 14.07"/>
                    </svg>
                  </div>
                  <ul class="dropdown-list">
                    <li class="check-box active">
                      <div class="form-check-box">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 20">
                          <polygon points="5.51 15.78 0 10.26 1.06 9.2 5.51 13.66 14.94 4.22 16 5.28 5.51 15.78"/>
                        </svg>
                      </div>
                      <span>Bratislava</span>
                    </li>
                    <li class="check-box">
                      <div class="form-check-box">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 20">
                          <polygon points="5.51 15.78 0 10.26 1.06 9.2 5.51 13.66 14.94 4.22 16 5.28 5.51 15.78"/>
                        </svg>
                      </div>
                      <span>Brezová pod Bradlom</span>
                    </li>
                    <li class="check-box">
                      <div class="form-check-box">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 20">
                          <polygon points="5.51 15.78 0 10.26 1.06 9.2 5.51 13.66 14.94 4.22 16 5.28 5.51 15.78"/>
                        </svg>
                      </div>
                      <span>Bučany</span>
                    </li>
                    <li class="check-box">
                      <div class="form-check-box">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 20">
                          <polygon points="5.51 15.78 0 10.26 1.06 9.2 5.51 13.66 14.94 4.22 16 5.28 5.51 15.78"/>
                        </svg>
                      </div>
                      <span>Bystričany</span>
                    </li>
                    <li class="check-box">
                      <div class="form-check-box">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                          <polygon points="4.84 15.11 0 10.26 1.06 9.2 4.84 12.99 12.94 4.89 14 5.95 4.84 15.11"/>
                        </svg>
                      </div>
                      <span>Bystrička</span>
                    </li>
                  </ul>
                </div>

                <div class="form-item-wrapper">
                  <label for="title">Stav podnetu</label>
                  <div class="dropdown-button">
                    Všetko
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                      <polygon points="7 14.07 0 7.07 1.14 5.93 7 11.79 12.86 5.93 14 7.07 7 14.07"/>
                    </svg>
                  </div>
                </div>

                <div class="form-item-wrapper">
                  <label for="title">Obec</label>
                  <div class="dropdown-button">
                    Všetko
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                      <polygon points="7 14.07 0 7.07 1.14 5.93 7 11.79 12.86 5.93 14 7.07 7 14.07"/>
                    </svg>
                  </div>
                </div>

                <div class="form-item-wrapper">
                  <label for="title">Kategória</label>
                  <div class="dropdown-button">
                    Všetko
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                      <polygon points="7 14.07 0 7.07 1.14 5.93 7 11.79 12.86 5.93 14 7.07 7 14.07"/>
                    </svg>
                  </div>
                </div>

                <div class="form-item-wrapper">
                  <label for="title">Rieši / Vybavuje</label>
                  <div class="dropdown-button">
                    Všetko
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
                      <polygon points="7 14.07 0 7.07 1.14 5.93 7 11.79 12.86 5.93 14 7.07 7 14.07"/>
                    </svg>
                  </div>
                </div>

                <div class="form-item-wrapper">
                  <label for="title">Ulica</label>
                  <input type="text">
                </div>

              </div>
            </div>


          </form>

        </div>
      </div>
    </div>

    <!-- Podnety -->
    <div class="podnety-con">
      <!-- Navigation -->
      <nav class="suggestions">
        <button class="button button-filter">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
            <path d="M15,1.25c-1.81,0-3.33,1.29-3.67,3H1v1.5h10.33c.35,1.71,1.86,3,3.67,3,2.07,0,3.75-1.68,3.75-3.75s-1.68-3.75-3.75-3.75ZM15,7.25c-1.24,0-2.25-1.01-2.25-2.25s1.01-2.25,2.25-2.25,2.25,1.01,2.25,2.25-1.01,2.25-2.25,2.25Z"/>
            <path d="M19,14.25h-10.33c-.35-1.71-1.86-3-3.67-3-2.07,0-3.75,1.68-3.75,3.75s1.68,3.75,3.75,3.75c1.81,0,3.33-1.29,3.67-3h10.33v-1.5ZM5,17.25c-1.24,0-2.25-1.01-2.25-2.25s1.01-2.25,2.25-2.25,2.25,1.01,2.25,2.25-1.01,2.25-2.25,2.25Z"/>
          </svg>
          <span>Filter</span>
        </button>
        <%= link_to issues_path(tab: 'list', q: params[:q]), class: class_names('button button-transparent button-list button-suggestion', 'button-suggestion-active': @tab == 'list') do %>
          <span>Zoznam</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
            <path d="M8.75,8.75H2.25V2.25h6.5v6.5ZM3.75,7.25h3.5v-3.5h-3.5v3.5Z"/>
            <path d="M17.75,8.75h-6.5V2.25h6.5v6.5ZM12.75,7.25h3.5v-3.5h-3.5v3.5Z"/>
            <path d="M8.75,17.75H2.25v-6.5h6.5v6.5ZM3.75,16.25h3.5v-3.5h-3.5v3.5Z"/>
            <path d="M17.75,17.75h-6.5v-6.5h6.5v6.5ZM12.75,16.25h3.5v-3.5h-3.5v3.5Z"/>
          </svg>
        <% end %>
        <%= link_to issues_path(tab: 'map'), class: class_names('button button-transparent button-map button-suggestion', 'button-suggestion-active': @tab == 'map') do %>
          <span>Mapa</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 15 20">
            <path d="M7.5,19.99l-.49-.42c-.27-.23-6.56-5.75-6.56-12.27C.45,3.41,3.61.25,7.5.25s7.05,3.16,7.05,7.05c0,6.51-6.29,12.04-6.56,12.27l-.49.42ZM7.5,1.75C4.44,1.75,1.95,4.24,1.95,7.3c0,4.83,4.11,9.27,5.55,10.67,1.44-1.41,5.55-5.85,5.55-10.67,0-3.06-2.49-5.55-5.55-5.55Z"/>
            <path d="M7.5,10.3c-1.65,0-3-1.35-3-3s1.35-3,3-3,3,1.35,3,3-1.35,3-3,3ZM7.5,5.8c-.83,0-1.5.67-1.5,1.5s.67,1.5,1.5,1.5,1.5-.67,1.5-1.5-.67-1.5-1.5-1.5Z"/>
          </svg>
        <% end %>
        <%= link_to issues_path(tab: 'stats'), class: class_names('button button-transparent button-statistics button-suggestion', 'button-suggestion-active': @tab == 'stats') do %>
          <span>Štatistika</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
            <path d="M18,2c-1.1,0-2,.9-2,2,0,.46.16.88.42,1.22l-3.37,5.8c-.09-.01-.18-.03-.28-.03-.31,0-.61.08-.87.21l-2.8-2.52c.08-.21.13-.44.13-.68,0-1.1-.9-2-2-2s-2,.9-2,2c0,.42.13.82.36,1.14l-3.2,4.89c-.12-.02-.25-.04-.39-.04-1.1,0-2,.9-2,2s.9,2,2,2,2-.9,2-2c0-.42-.13-.82-.36-1.14l3.2-4.89c.12.02.25.04.39.04.31,0,.61-.08.87-.21l2.8,2.52c-.08.21-.13.44-.13.68,0,1.1.9,2,2,2s2-.9,2-2c0-.46-.16-.88-.42-1.22l3.37-5.8c.09.01.18.03.28.03,1.1,0,2-.9,2-2s-.9-2-2-2Z"/>
          </svg>
        <% end %>
        <button class="button button-transparent button-location">
          <span>Moja poloha</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
            <circle cx="10" cy="10" r="1.5" />
            <path d="M19.75,9.25h-2.04c-.35-3.68-3.29-6.61-6.96-6.96V.25h-1.5v2.04c-3.68.35-6.61,3.29-6.96,6.96H.25v1.5h2.04c.35,3.68,3.29,6.61,6.96,6.96v2.04h1.5v-2.04c3.68-.35,6.61-3.29,6.96-6.96h2.04v-1.5ZM10.75,16.2v-1.95h-1.5v1.95c-2.85-.34-5.11-2.6-5.45-5.45h1.95v-1.5h-1.95c.34-2.85,2.6-5.11,5.45-5.45v1.95h1.5v-1.95c2.85.34,5.11,2.6,5.45,5.45h-1.95v1.5h1.95c-.34,2.85-2.6,5.11-5.45,5.45Z"/>
          </svg>
        </button>
        <button class="button button-transparent">
          <span>Zoradiť</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 20">
            <polygon points="7 14.07 0 7.07 1.14 5.93 7 11.79 12.86 5.93 14 7.07 7 14.07"/>
          </svg>
        </button>
      </nav>

      <%= render partial: @tab %>

    </div>
  </div>
</section>