              <span></span>
              <span></span>
            </a>
            <% if logged_in? %>
              <%= link_to profile_path, class: "account" do %>
                <figure>
                  <picture>
                    <%= image_tag "muz.jpg" %>
                  </picture>
                </figure>
                <div class="name"><%= current_user.firstname %></div>
                <div class="arrow"></div>
              <% end %>
            <% end %>

            <div class="mobile-buttons-nav">
              <%= link_to "Nahlásiť podnet", new_issues_draft_path %>
              <%= link_to "Položiť otázku", new_question_path %>
              <%= link_to "Dať pochvalu", new_praise_path %>
            </div>

            <%= link_to "Nahlásené dopyty", issues_path %>
            <%= link_to 'Aktuality', '/aktuality' %>
            <%= link_to "Pravidlá", "/pravidla" %>
            <%= link_to "Pridajte sa", "/pridajte-sa" %>
            <%= link_to "O nás", "/o-nas" %>
            <%= link_to "Podporte nás", "/podporte-nas" %>
          </div>
        </div>
        <div class="buttons-con">
          <%= link_to "Nahlásiť podnet", new_issues_draft_path, class: "add-button" %>
          <%= link_to issues_path, class: "icon search" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
              <circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke-miterlimit="10"/>
              <path d="M15,15l5,5" fill="none" stroke-miterlimit="10"/>
            </svg>
          <% end %>
          <% if logged_in? %>
            <%= link_to profile_path, class: "icon login" do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                <circle cx="12" cy="8" r="4" fill="none"/>
                <path d="M19,21v-1c0-2.21-1.79-4-4-4h-6c-2.21,0-4,1.79-4,4v1" fill="none"/>
              </svg>
              <span class="logged"><%= current_user.firstname %> <%= current_user.lastname %></span>
            <% end %>
          <% else %>
            <%= link_to rodauth.login_path, class: "icon login" do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                <circle cx="12" cy="8" r="4" fill="none"/>
                <path d="M19,21v-1c0-2.21-1.79-4-4-4h-6c-2.21,0-4,1.79-4,4v1" fill="none"/>
              </svg>
              <span class="logged">Prihlásiť</span>
            <% end %>
          <% end %>
          <a class="menu-button" data-action="navigation#open">
            <span></span>
            <span></span>
            <span></span>
          </a>
